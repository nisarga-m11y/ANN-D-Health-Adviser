    const synth = window.speechSynthesis;
    if (!synth) {
      setError("Text-to-speech is not supported in this browser.");
      return;
    }

    const value = (text || "").trim();
    if (!value) {
      setError("No text available to speak yet.");
      return;
    }

    const desiredLang = speechLang === "kn" ? "kn-IN" : "en-IN";

    synth.cancel();
    const utterance = new SpeechSynthesisUtterance(value);
    utterance.lang = desiredLang;

    const voices = synth.getVoices() || [];
    const prefix = speechLang === "kn" ? "kn" : "en";
    const preferredVoice =
      voices.find((voice) => (voice.lang || "").toLowerCase().startsWith(prefix + "-in")) ||
      voices.find((voice) => (voice.lang || "").toLowerCase().startsWith(prefix));
    if (preferredVoice) {
      utterance.voice = preferredVoice;
    }

    utterance.rate = speechLang === "kn" ? 0.92 : 0.98;
    utterance.pitch = 1;
    synth.speak(utterance);
  }


    const value = (text || "").trim();
    if (!value) {
      setError("No voice text available yet. Send a new message first.");
      return;
