      const voices = synth.getVoices() || [];
      setTtsVoicesLoaded(true);
      setHasKannadaVoice(voices.some((voice) => (voice.lang || "").toLowerCase().startsWith("kn")));
    }

    refreshVoices();
    synth.onvoiceschanged = refreshVoices;

