    utterance.lang = "kn-IN";

    const voices = synth.getVoices() || [];
    const kannadaVoice = voices.find((voice) => (voice.lang || "").toLowerCase().startsWith("kn"));
    if (kannadaVoice) {
      utterance.voice = kannadaVoice;
    }

    utterance.rate = 0.92;
    utterance.pitch = 1;
    synth.speak(utterance);
  }



