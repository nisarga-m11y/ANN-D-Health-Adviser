DJANGO_SECRET_KEY=replace-with-a-secure-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
# Set USE_MYSQL=True to use MySQL, or False to use local SQLite (default).
USE_MYSQL=False

MYSQL_DATABASE=health_chatbot
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OTP (Email + Mobile)
OTP_EXPIRY_SECONDS=60
# For local dev only: returns the OTP in the mobile "send" API response
OTP_DEBUG_RETURN_CODE=True

# Email (Gmail SMTP)
# Use a Gmail "App Password" (recommended) instead of your main password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=ANN-D Health Advisor <you@gmail.com>

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
EMERGENCY_CALL_NUMBER=+919380766742

# Twilio callback calling (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Optional: bridge the callback to another number after greeting (E.164)
TWILIO_BRIDGE_TO_NUMBER=
# Optional: allow callbacks only to these numbers (comma separated)
CALLBACK_ALLOWLIST=+919999999999
# Optional: rate-limit callback requests per user
CALLBACK_RATE_LIMIT_SECONDS=120

